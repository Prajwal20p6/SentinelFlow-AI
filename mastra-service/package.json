{
  "name": "sentinelflow-mastra-service",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:axios --external:express --external:dotenv --external:@mastra/core --external:@mastra/memory",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@mastra/core": "latest",
    "@mastra/memory": "latest",
    "express": "latest",
    "dotenv": "latest",
    "axios": "latest",
    "qdrant-js": "latest"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "latest",
    "tsx": "latest",
    "@types/express": "latest",
    "@types/node": "latest"
  }
}
