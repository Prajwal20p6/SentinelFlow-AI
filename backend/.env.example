# ============================================================
# SentinelFlow AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All values shown are development defaults.

# ── General ──────────────────────────────────────────────────
PROJECT_NAME=SentinelFlow AI
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Backend (FastAPI) ────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000/ws
FRONTEND_PORT=3000

# ── Database (PostgreSQL) ───────────────────────────────────
# For hackathon/demo: uses SQLite fallback if PostgreSQL unavailable
DATABASE_URL=sqlite:///./sentinelflow.db
# Production: postgresql+asyncpg://sentinelflow:password@localhost:5432/sentinelflow

# ── Redis ───────────────────────────────────────────────────
# For hackathon/demo: uses in-memory fallback if Redis unavailable
REDIS_URL=redis://localhost:6379/0

# ── Qdrant (Vector Database) ────────────────────────────────
QDRANT_MODE=local
QDRANT_PATH=./data/qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Authentication ──────────────────────────────────────────
SECRET_KEY=sentinelflow-dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption ──────────────────────────────────────────────
ENCRYPTION_KEY=sentinelflow-aes256-encryption-key!!

# ── LLM Provider ────────────────────────────────────────────
LLM_PROVIDER=simulation
# Options: openai, anthropic, simulation
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Mastra Workflow Engine ──────────────────────────────────
MASTRA_URL=http://localhost:4111
MASTRA_ENABLED=true

# ── Enkrypt AI Safety ───────────────────────────────────────
ENKRYPT_ENABLED=true
ENKRYPT_API_KEY=
ENKRYPT_STRICTNESS=high

# ── Slack Integration ───────────────────────────────────────
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=http://localhost:8000/api/v1/integrations/slack/webhook
SLACK_CHANNEL=#sentinelflow-alerts

# ── Feature Flags ───────────────────────────────────────────
FF_DEMO_MODE=true
FF_SLACK_NOTIFICATIONS=false
FF_CLOUD_REMEDIATION=true
FF_MFA_REQUIRED=false
FF_WEBSOCKET_UPDATES=true

# ── Observability ───────────────────────────────────────────
OTEL_ENABLED=true
OTEL_EXPORTER=console
OTEL_SERVICE_NAME=sentinelflow-backend
PROMETHEUS_PORT=9090
